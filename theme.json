{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#ffffff",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#888888",
					"name": "Secondary"
				},
				{
					"slug": "muted",
					"color": "#666666",
					"name": "Muted"
				},
				{
					"slug": "background",
					"color": "#000000",
					"name": "Background"
				},
				{
					"slug": "surface",
					"color": "#0a0a0a",
					"name": "Surface"
				},
				{
					"slug": "border",
					"color": "#222222",
					"name": "Border"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				}
			],
			"gradients": [
				{
					"slug": "dark-fade",
					"gradient": "linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 100%)",
					"name": "Dark Fade"
				},
				{
					"slug": "radial-glow",
					"gradient": "radial-gradient(circle at center, rgba(255,255,255,0.05) 0%, transparent 70%)",
					"name": "Radial Glow"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
					"slug": "primary",
					"name": "Inter"
				},
				{
					"fontFamily": "'SF Mono', 'Fira Code', 'Consolas', monospace",
					"slug": "mono",
					"name": "Monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "tiny",
					"size": "12px",
					"name": "Tiny"
				},
				{
					"slug": "small",
					"size": "14px",
					"name": "Small"
				},
				{
					"slug": "normal",
					"size": "16px",
					"name": "Normal"
				},
				{
					"slug": "medium",
					"size": "18px",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "24px",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "32px",
					"name": "X-Large"
				},
				{
					"slug": "huge",
					"size": "48px",
					"name": "Huge"
				},
				{
					"slug": "giant",
					"size": "72px",
					"name": "Giant"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vh", "vw"],
			"spacingScale": {
				"steps": 10
			}
		},
		"layout": {
			"contentSize": "1000px",
			"wideSize": "1200px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "#e5e5e5"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"fontSize": "var(--wp--preset--font-size--normal)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"left": "24px",
				"right": "24px"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)",
					"fontWeight": "600",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "clamp(40px, 8vw, 72px)",
					"fontWeight": "500",
					"lineHeight": "1.05",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "clamp(32px, 5vw, 48px)",
					"lineHeight": "1.1"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "32px",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "24px",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--white)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--secondary)"
					}
				}
			},
			"button": {
				"border": {
					"radius": "6px",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--white)",
					"text": "var(--wp--preset--color--black)"
				},
				"typography": {
					"fontWeight": "500",
					"fontSize": "14px"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"bottom": "14px",
						"left": "28px",
						"right": "28px"
					}
				},
				":hover": {
					"color": {
						"background": "transparent",
						"text": "var(--wp--preset--color--white)"
					},
					"border": {
						"color": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--secondary)"
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--white)"
							}
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primary)",
					"fontWeight": "700",
					"fontSize": "18px",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--white)"
				}
			},
			"core/paragraph": {
				"color": {
					"text": "#e5e5e5"
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "24px"
				}
			},
			"core/column": {
				"color": {
					"background": "var(--wp--preset--color--surface)"
				},
				"border": {
					"radius": "12px",
					"width": "1px",
					"color": "var(--wp--preset--color--border)"
				},
				"spacing": {
					"padding": "48px"
				}
			},
			"core/group": {
				"spacing": {
					"padding": "0"
				}
			},
			"core/cover": {
				"spacing": {
					"padding": {
						"top": "120px",
						"bottom": "120px"
					}
				}
			},
			"core/quote": {
				"color": {
					"background": "var(--wp--preset--color--surface)"
				},
				"border": {
					"radius": "12px",
					"width": "1px",
					"color": "var(--wp--preset--color--border)",
					"left": {
						"width": "0"
					}
				},
				"spacing": {
					"padding": "48px"
				}
			},
			"core/table": {
				"border": {
					"color": "var(--wp--preset--color--border)"
				}
			},
			"core/separator": {
				"color": {
					"background": "var(--wp--preset--color--border)"
				},
				"border": {
					"color": "var(--wp--preset--color--border)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-blank",
			"title": "Blank Page",
			"postTypes": ["page"]
		},
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": ["page"]
		}
	]
}
