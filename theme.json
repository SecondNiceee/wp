{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "main",
					"color": "#1a1a2e",
					"name": "Main"
				},
				{
					"slug": "secondary",
					"color": "#6b6b80",
					"name": "Secondary"
				},
				{
					"slug": "accent",
					"color": "#ff3d7f",
					"name": "Accent"
				},
				{
					"slug": "background",
					"color": "#e6e6e6",
					"name": "Background"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "dark",
					"color": "#111111",
					"name": "Dark"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Arial', sans-serif",
					"slug": "main",
					"name": "Main"
				},
				{
					"fontFamily": "'Georgia', serif",
					"slug": "secondary",
					"name": "Secondary"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "14px",
					"name": "Small"
				},
				{
					"slug": "normal",
					"size": "18px",
					"name": "Normal"
				},
				{
					"slug": "medium",
					"size": "22px",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "32px",
					"name": "Large"
				},
				{
					"slug": "xlarge",
					"size": "42px",
					"name": "Extra Large"
				},
				{
					"slug": "huge",
					"size": "56px",
					"name": "Huge"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vh", "vw"],
			"padding": true,
			"margin": true
		},
		"layout": {
			"contentSize": "992px",
			"wideSize": "1200px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--dark)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--main)",
			"fontSize": "var(--wp--preset--font-size--normal)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				},
				"color": {
					"text": "var(--wp--preset--color--main)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				}
			},
			"button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontWeight": "bold"
				}
			}
		}
	}
}
